# Root reference file for local development.
#
# The backend reads backend/.env.
# The frontend reads frontend/.env.local.
#
# Copy from the service-specific examples for actual runtime use:
#   cp backend/.env.example backend/.env
#   cp frontend/.env.example frontend/.env.local

# Backend
SECRET_KEY=change-me-in-env
ACCESS_TOKEN_EXPIRE_MINUTES=10080
SQLITE_FILENAME=app.db
DATA_DIR=backend/data
FRONTEND_ORIGIN=http://localhost:5173
TRANSCRIPTION_PROVIDER=stub
TRANSCRIPTION_MODEL=stub-transcriber-v1
TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_TIMEOUT_SECONDS=60
TRANSCRIPTION_LANGUAGE_CODE=en
EXTRACTION_PROVIDER=stub
EXTRACTION_MODEL=stub-extractor-v1
EXTRACTION_BASE_URL=https://openrouter.ai/api/v1
EXTRACTION_API_KEY=
EXTRACTION_TIMEOUT_SECONDS=60
EXTRACTION_PROMPT_VERSION=v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Property Voice Agent PoC

# Frontend
VITE_API_BASE_URL=